FROM debian:bookworm-slim AS test-build

ARG BUILD_JOBS=2

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
    autoconf automake bash bsdextrautils build-essential ca-certificates \
    libboost-all-dev libevent-dev libminiupnpc-dev libnatpmp-dev \
    libsqlite3-dev libtool libzmq3-dev pkg-config python3 systemtap-sdt-dev \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /src
COPY . .

RUN ./autogen.sh \
 && ./configure \
    --without-gui \
    --enable-tests \
    --disable-bench \
    --disable-fuzz-binary \
    --disable-bdb \
 && make -C src -j"${BUILD_JOBS}" bitcoincashIId bitcoincashII-cli test/test_bitcoinII

FROM test-build AS test-runner

RUN src/test/test_bitcoinII --run_test=pow_tests/fivetrat_nested_proof_tiers --log_level=test_suite \
 && src/test/test_bitcoinII --run_test=pow_tests/fivetrat_production_consensus_parameters --log_level=test_suite \
 && src/test/test_bitcoinII --run_test=pow_tests/fivetrat_five_minute_upgrade_boundary --log_level=test_suite \
 && src/test/test_bitcoinII --run_test=pow_tests/fivetrat_stall_recovery_is_bounded --log_level=test_suite \
 && src/test/test_bitcoinII --run_test=pow_tests/fivetrat_fast_blocks_raise_difficulty_quickly --log_level=test_suite \
 && src/test/test_bitcoinII --run_test=validation_tests/block_subsidy_test --log_level=test_suite \
 && src/test/test_bitcoinII --run_test=validation_tests/subsidy_limit_test --log_level=test_suite \
 && BITCOINIID=/src/src/bitcoincashIId \
    BITCOINIICLI=/src/src/bitcoincashII-cli \
    python3 test/functional/feature_bch2_consensus.py --configfile=/src/test/config.ini
